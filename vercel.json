{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/v1/(.*)",
      "dest": "/api/v1.js"
    },
    {
      "src": "/anthropic/(.*)",
      "dest": "/api/anthropic.js"
    },
    {
      "src": "/token_plan/(.*)",
      "dest": "/api/v1.js"
    },
    {
      "src": "/coding_plan/(.*)",
      "dest": "/api/v1.js"
    },
    {
      "src": "/chat",
      "dest": "/public/chat.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
