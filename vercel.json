{
  "version": 2,
  "functions": {
    "vercel/index.js": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "/v1/(.*)",
      "dest": "/vercel/index.js"
    },
    {
      "src": "/token_plan/(.*)",
      "dest": "/vercel/index.js"
    },
    {
      "src": "/([^/]+)/v1/(.*)",
      "dest": "/vercel/index.js"
    },
    {
      "src": "/([^/]+)/(.*)",
      "dest": "/vercel/index.js"
    }
  ]
}
